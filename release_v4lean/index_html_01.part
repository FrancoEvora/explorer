ticle class="profileHero"><div id="profileCover" class="cover"></div><div class="profileHead"><button id="profilePhoto" class="profilePic">E<i>＋</i></button><div><p class="eyebrow">PERFIL DE EXPLORADOR</p><h1 id="profileName">Explorador</h1><p id="profileHandle"></p></div></div><div class="profileStats"><div><b id="pTrails">0</b><small>trilhas</small></div><div><b id="pObs">0</b><small>observações</small></div><div><b id="pFollowers">0</b><small>seguidores</small></div></div></article><article class="panel"><form id="profileForm" class="stack"><div class="two"><label class="field">Nome público<input id="pName"></label><label class="field">Usuário<input id="pUser"></label></div><label class="field">Bio<textarea id="pBio" rows="3"></textarea></label><div class="two"><label class="field">Localização<input id="pLocation"></label><label class="field">Equipamentos<input id="pGear"></label></div><div class="actions"><button class="btn lime">Salvar perfil</button><button id="logout" type="button" class="btn ghost">Sair</button></div></form><input id="profileFile" type="file" accept="image/*" capture="user" class="hide"></article><article class="panel"><div class="section"><div><p class="eyebrow">SEGURANÇA</p><h2>Contatos de emergência</h2></div><button id="addContact" class="btn ghost">Adicionar</button></div><div id="contacts" class="list empty">Nenhum contato cadastrado.</div></article></section>
</main><nav><button class="on" data-go="home"><span>⌂</span>Início</button><button data-go="mapPage"><span>⌖</span>Mapa</button><button class="plus" data-go="record"><span>＋</span>Registrar</button><button data-go="explore"><span>◉</span>Explorar</button><button data-go="profile"><span>◎</span>Perfil</button></nav><button id="sos" class="sos">SOS</button></div>
