<!doctype html><html lang="pt-BR"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover"><meta name="theme-color" content="#061722"><meta name="apple-mobile-web-app-capable" content="yes"><title>Explorer 4.0</title><link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"><link rel="stylesheet" href="styles.css"></head><body>
<div id="boot" class="boot"><div class="bootbox"><div class="mark"></div><h1>Explorer 4.0</h1><p>Preparando sua próxima aventura…</p><i></i></div></div>
<section id="auth" class="auth hide"><div class="authHero"><div class="mark big"></div><p class="eyebrow">AVENTURA · NATUREZA · COMUNIDADE</p><h1>Explore. Registre.<br>Compartilhe.</h1><p>Trilhas ao vivo, fotografia, vida selvagem, alertas de risco e segurança em campo.</p></div><div class="authCard"><div class="brand"><div class="mark"></div><div><b>Explorer</b><small>rede social outdoor</small></div></div><div class="tabs"><button data-mode="in" class="on">Entrar</button><button data-mode="up">Criar conta</button><button data-mode="public">Explorar</button></div><form id="authForm" class="stack"><label id="nameRow" class="field hide">Nome<input id="authName" autocomplete="name"></label><label class="field">E-mail<input id="authEmail" type="email" required autocomplete="email"></label><label class="field">Senha<input id="authPass" type="password" minlength="8" required autocomplete="current-password"></label><button id="authSend" class="btn lime">Entrar</button></form><button id="forgot" class="linkbtn">Esqueci minha senha</button><div id="authMsg" class="note">Entre ou explore as publicações abertas.</div></div></section>
<div id="app" class="hide"><header><button class="brand" data-go="home"><div class="mark"></div><div><small>EXPLORER 4.0</small><b>Comunidade ao ar livre</b></div></button><div class="headRight"><span id="cloud" class="status">● online</span><button id="avatarTop" class="avatar">E</button></div></header><main>
<section id="home" class="page on"><article class="hero"><div><p class="eyebrow">PRONTO PARA EXPLORAR?</p><h1 id="hello">Seu próximo caminho começa aqui.</h1><p id="trailText">Inicie uma trilha para gravar rota, tempo, observações e riscos.</p><div class="actions"><button id="newTrail" class="btn lime">＋ Nova trilha</button><button class="btn blue" data-go="explore">◉ Comunidade</button><button id="permissionBtn" class="btn ghost">Permissões</button></div></div><div class="mark heroMark"></div></article><div class="stats"><article><small>Trilhas</small><b id="statTrails">0</b></article><article><small>Observações</small><b id="statObs">0</b></article><article><small>Riscos</small><b id="statRisks">0</b></article><article><small>Distância atual</small><b id="statDist">0 km</b></article></div><article id="liveTrail" class="panel hide"><div class="section"><div><p class="eyebrow">TRILHA EM GRAVAÇÃO</p><h2 id="liveName"></h2></div><span class="rec"></span></div><div class="liveStats"><div><small>Tempo</small><b id="liveTime">00:00</b></div><div><small>Distância</small><b id="liveDist">0 km</b></div><div><small>Pontos</small><b id="livePoints">0</b></div><div><small>Precisão</small><b id="liveAccuracy">—</b></div></div><div class="actions"><button id="pauseTrail" class="btn ghost">Pausar</button><button id="trailObservation" class="btn blue">Observação</button><button id="trailRisk" class="btn orange">Risco</button><button id="finishTrail" class="btn danger">Finalizar</button></div></article><article class="panel"><div class="section"><div><p class="eyebrow">ATIVIDADE</p><h2>Meus registros recentes</h2></div></div><div id="myRecent" class="list empty">Nenhum registro ainda.</div></article></section>
<section id="mapPage" class="page"><div class="title"><div><p class="eyebrow">MAPA DE CAMPO</p><h1>Explore com contexto</h1></div><div class="actions"><button id="mapLocate" class="btn ghost">⌖ Minha posição</button><button id="mapFit" class="btn ghost">Enquadrar</button></div></div><div class="mapBox"><div id="map" class="map"></div><div class="mapBtns"><button id="mapMark" class="mapBtn lime">＋<small>Marcar</small></button><button id="mapRisk" class="mapBtn orange">⚠<small>Risco</small></button><button id="mapObs" class="mapBtn blue">◉<small>Observar</small></button></div></div></section>
<section id="record" class="page"><div class="title"><div><p class="eyebrow">REGISTRO RÁPIDO</p><h1>O que encontrou?</h1></div></div><div class="recordGrid"><button id="newObs" class="recordCard wildlife"><span>◉</span><b>Vida selvagem</b><small>Foto, áudio e identificação assistida</small></button><button id="newRisk" class="recordCard risk"><span>⚠</span><b>Risco ou ocorrência</b><small>Buracos, erosões, bloqueios e alertas</small></button><button id="newMarker" class="recordCard marker"><span>⌖</span><b>Marcar posição</b><small>Água, mirante, acesso ou abrigo</small></button><button id="quickPhoto" class="recordCard photo"><span>▣</span><b>Fotografia</b><small>Registre um momento geolocalizado</small></button></div><article class="panel"><p class="eyebrow">PERMISSÕES</p><div id="permList"></div></article></section>
<section id="explore" class="page"><div class="title"><div><p class="eyebrow">COMUNIDADE</p><h1>Descubra histórias reais</h1></div><button id="feedRefresh" class="btn ghost">Atualizar</button></div><input id="feedSearch" class="search" placeholder="Buscar trilha, local ou espécie"><div class="filters"><button class="on" data-filter="all">Todos</button><button data-filter="trail">Trilhas</button><button data-filter="observation">Vida selvagem</button><button data-filter="risk">Riscos</button></div><div id="feed" class="feed"><div class="empty">Carregando publicações…</div></div></section>
<section id="profile" class="page"><ar