(()=>{'use strict';const X=window.X,$=X.$,$$=X.$$,S=X.state;Object.assign(X,{openPermissions,openTrail,pauseTrail,finishTrail,restoreTrail,openObservation,openRisk,openMarker,saveProfile,uploadAvatar,openContact,loadContacts,openSos,openPasswordReset,showTrail});function sheet(title,intro,body,cls=''){X.modal(`<div class="sheet ${cls}"><button class="close" data-close>×</button><p class="eyebrow">EXPLORER 4.0</p><h2>${title}</h2><p class="intro">${intro}</p>${body}</div>`)}async function openPermissions(silent=false){if(silent&&localStorage.getItem('explorer-perms'))return renderPerms();sheet('Permissões de campo','O Explorer usa recursos do aparelho somente para funções solicitadas por você.',`<div id="permModal"><div class="perm"><span>⌖</span><div><b>Localização</b><small>Rotas, marcadores e SOS</small></div><i id="pl">pendente</i></div><div class="perm"><span>▣</span><div><b>Câmera</b><small>Fauna, riscos e perfil</small></div><i id="pc">pendente</i></div><div class="perm"><span>●</span><div><b>Microfone</b><small>Áudios de campo</small></div><i id="pm">pendente</i></div></div><div class="actions"><button class="btn ghost" data-close>Agora não</button><button id="grantAll" class="btn lime">Conceder permissões</button></div>`);$('grantAll').onclick=async()=>{for(const [id,fn]of[['pl',()=>X.locate()],['pc',()=>navigator.mediaDevices.getUserMedia({video:true}).then(s=>s.getTracks().forEach(t=>t.stop()))],['pm',()=>navigator.mediaDevices.getUserMedia({audio:true}).then(s=>s.getTracks().forEach(t=>t.stop()))]]){try{await fn();$(id).textContent='liberada';$(id).className='ok'}catch{$(id).textContent='não liberada'}}localStorage.setItem('explorer-perms','1');renderPerms()}}async function renderPerms(){const perms=[['Localização','Rotas e segurança','geolocation'],['Câmera','Fotos e identificação','camera'],['Microfone','Áudios de campo','microphone']];$('permList').innerHTML=perms.map(x=>`<div class="perm"><span>●</span><div><b>${x[0]}</b><small>${x[1]}</small></div><i>${x[2]==='geolocation'&&navigator.geolocation?'disponível':navigator.mediaDevices?'disponível':'indisponível'}</i></div>`).join('')}function openTrail(){sheet('Criar trilha','Defina os dados antes de começar a gravação em tempo real.',`<form id="trailForm" class="stack"><label class="field">Nome<input id="tName" required></label><div class="two"><label class="field">Local<input id="tPlace"></label><label class="field">Atividade<select id="tType"><option value="caminhada">Caminhada</option><option value="fotografia">Fotografia</option><option value="observacao">Observação de fauna</option><option value="bike">Ciclismo</option><option value="inspecao">Inspeção</option></select></label></div><label class="field">Descrição<textarea id="tDesc"></textarea></label><label class="toggle"><input id="tPublic" type="checkbox" checked> Publicar na comunidade</label><div class="actions"><button class="btn ghost" type="button" data-close>Cancelar</button><button class="btn lime">Iniciar GPS</button></div></form>`);$('trailForm').onsubmit=startTrail}async function startTrail(e){e.preventDefault();if(!X.user)return X.toast('Entre para gravar trilhas.','error');await X.locate();S.trail={id:X.uid('trail'),name:$('tName').value,place:$('tPlace').value,activity:$('tType').value,description:$('tDesc').value,isPublic:$('tPublic').checked,start:new Date().toISOString(),distance:0};S.points=[];S.paused=false;S.pausedMs=0;localStorage.setItem('explorer-active',JSON.stringify({trail:S.trail,points:[]}));X.closeModal();$('liveTrail').classList.remove('hide');$('liveName').textContent=S.trail.name;$('trailText').textContent=S.trail.name+' · GPS em gravação';S.watch=navigator.geolocation.watchPosition(track,e=>X.toast(e.message,'error'),{enableHighAccuracy:true,maximumAge:2000,timeout:15000});S.timer=setInterval(renderLive,1000);renderLive();X.show('home')}function dist(a,b){const R=6371000,r=x=>x*Math.PI/180,d1=r(b.lat-a.lat),d2=r(b.lng-a.lng),q=Math.sin(d1/2)**2+Math.cos(r(a.lat))*Math.cos(r(b.lat))*Math.sin(d2/2)**2;return 2*R*Math.asin(Math.sqrt(q))}function track(p){X.setCurrent(p.coords);if(S.paused)return;const q={lat:p.coords.latitude,lng:p.coords.longitude,alt:p.coords.altitude,accuracy:p.coords.accuracy,time:new Date().toISOString()};if(S.points.length){const d=dist(S.points.at(-1),q);if(d<200)S.trail.distance+=d}S.points.push(q);localStorage.setItem('explorer-active',JSON.stringify({trail:S.trail,points:S.points,pausedMs:S.pausedMs}));$('liveAccuracy').textContent=Math.round(q.accuracy||0)+' m';$('statDist').textContent=X.km(S.trail.distance);X.renderMap();renderLive()}function renderLive(){if(!S.trail)return;const ms=Date.now()-new Date(S.trail.start)-S.pausedMs-(S.paused&&S.pauseStart?Date.now()-S.pauseStart:0),sec=Math.max(0,Math.floor(ms/1000));$('liveTime').textContent=String(Math.floor(sec/60)).padStart(2,'0')+':'+String(sec%60).padStart(2,'0');$('liveDist').textContent=X.km(S.trail.distance);$('livePoints').textContent=S.points.length}function pauseTrail(){if(!S.trail)return;S.paused=!S.paused;if(S.paused){S.pauseStart=Date.now();$('pauseTrail').textContent='Retomar'}else{S.pausedMs+=Date.now()-S.pauseStart;S.pauseStart=0;$('pauseTrail').textContent='Pausar'}renderLive()}async function finishTrail(){if(!S.trail)return;if(!confirm('Finalizar e salvar esta trilha?'))return;clearWatch();const end=new Date().toISOString(),duration=Math.floor((Date.now()-new Date(S.trail.start)-S.pausedMs)/1000),row={id:S.trail.id,user_id:X.user.id,name:S.trail.name,place:S.trail.place,start_notes:S.trail.description,start_time:S.trail.start,end_time:end,distance_meters:S.trail.distance,is_active:false,is_public:S.trail.isPublic,activity_type:S.trail.activity,duration_seconds:duration,paused_seconds:Math.floor(S.pausedMs/1000),description:S.trail.description};con