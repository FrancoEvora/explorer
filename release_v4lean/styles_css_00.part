:root{--bg:#04131e;--panel:#0c2b3a;--panel2:#113748;--text:#f5fbff;--muted:#9eb6c2;--line:#ffffff1d;--lime:#bdff18;--blue:#168cff;--orange:#ff721c;--pink:#ff3d8d;--red:#ff4057;--safe:env(safe-area-inset-bottom,0px)}*{box-sizing:border-box}body{margin:0;min-height:100vh;background:radial-gradient(circle at 10% -5%,#15576b,transparent 34rem),linear-gradient(#061924,#020b12 72%);color:var(--text);font-family:Inter,system-ui,-apple-system,sans-serif}button,input,select,textarea{font:inherit}button{cursor:pointer}.hide{display:none!important}.eyebrow{margin:0;color:var(--lime);font-size:.72rem;font-weight:950;letter-spacing:.14em}.boot{position:fixed;inset:0;z-index:99;display:grid;place-items:center;background:#061722}.bootbox{text-align:center;width:min(390px,88vw)}.bootbox h1{font-size:2.5rem;margin:12px 0 3px}.bootbox p{color:var(--muted)}.bootbox>i{display:block;height:7px;background:linear-gradient(90deg,var(--lime),var(--blue),var(--pink));border-radius:10px;animation:load 1.2s infinite}@keyframes load{50%{transform:scaleX(.35)}}.mark{width:58px;height:58px;border-radius:50%;position:relative;background:conic-gradient(var(--lime) 0 25%,var(--blue) 0 50%,var(--pink) 0 75%,var(--orange) 0);border:7px solid #071923;box-shadow:0 0 0 5px var(--lime),0 15px 35px #0008}.mark:after{content:"";position:absolute;inset:17px;background:#f7fbff;transform:rotate(45deg)}.mark.big{width:95px;height:95px;border-width:10px;box-shadow:0 0 0 7px var(--lime),0 22px 50px #0008}.mark.big:after{inset:28px}.auth{min-height:100vh;padding:25px;display:grid;grid-template-columns:1.1fr .8fr;gap:26px;align-items:center;max-width:1080px;margin:auto}.authHero,.authCard,.panel,.hero,.mapBox,.profileHero{border:1px solid var(--line);background:linear-gradient(150deg,#0e3444ee,#071d29f5);border-radius:28px;box-shadow:0 22px 70px #0006}.authHero{padding:55px;min-height:610px;display:flex;flex-direction:column;justify-content:center;background:linear-gradient(140deg,#0b4355,#0a2633 58%,#24421c)}.authHero h1{font-size:4rem;line-height:.95;letter-spacing:-.07em;margin:20px 0}.authHero>p:last-child{color:#c0d3dc;max-width:50ch;line-height:1.6}.authCard{padding:27px}.brand{display:flex;align-items:center;gap:12px;border:0;background:none;color:#fff;text-align:left}.brand b{display:block;font-size:1.35rem}.brand small{display:block;color:var(--muted)}.tabs{display:grid;grid-template-columns:repeat(3,1fr);gap:5px;padding:5px;background:#0003;border-radius:16px;margin:20px 0}.tabs button,.filters button{border:0;background:#ffffff0a;color:#a7bdc7;padding:10px;border-radius:12px;font-weight:850}.tabs button.on,.filters button.on{background:var(--lime);color:#071720}.stack{display:grid;gap:13px}.field{display:grid;gap:6px;font-size:.82rem;font-weight:800;color:#d8e7ed}.field input,.field select,.field textarea,.search{width:100%;padding:13px;border-radius:14px;border:1px solid var(--line);background:#061923;color:#fff;outline:0}.field input:focus,.field textarea:focus,.search:focus{border-color:var(--lime);box-shadow:0 0 0 3px #bdff1820}.btn{border:0;border-radius:14px;min-height:45px;padding:10px 15px;font-weight:950;display:inline-flex;align-items:center;justify-content:center;gap:6px}.btn.lime{background:var(--lime);color:#071720}.btn.blue{background:var(--blue);color:#fff}.btn.orange{background:var(--orange);color:#fff}.btn.danger{background:var(--red);color:#fff}.btn.ghost{background:#ffffff12;color:#fff;border:1px solid var(--line)}.linkbtn{border:0;background:none;color:var(--lime);font-weight:850;padding:10px}.note{margin-top:10px;padding:11px;border-radius:13px;background:#ffffff0b;color:var(--muted)}.note.err{color:#ffc3cb;background:#ff40571d}.note.ok{color:#dcff8a;background:#bdff1815}.two{display:grid;grid-template-columns:1fr 1fr;gap:11px}header{max-width:1120px;margin:auto;padding:13px 17px;display:flex;justify-content:space-between;align-items:center}.headRight{display:flex;align-items:center;gap:10px}.status{font-size:.78rem;color:var(--lime)}.avatar{width:43px;height:43px;border-radius:50%;border:2px solid var(--lime);background:linear-gradient(135deg,var(--blue),var(--pink));color:#fff;font-weight:950;overflow:hidden}.avatar img,.profilePic img{width:100%;height:100%;object-fit:cover}main{max-width:1120px;margin:auto;padding:7px 17px calc(105px + var(--safe))}.page{display:none;gap:15px}.page.on{display:grid}.hero{min-height:265px;padding:40px;display:grid;grid-template-columns:1fr auto;align-items:center;background:linear-gradient(125deg,#0b4253,#0a2936 58%,#24431d)}.hero h1{font-size:clamp(2.2rem,5vw,4rem);line-height:1;letter-spacing:-.06em;margin:10px 0}.hero p:not(.eyebrow){color:#bdd0d8}.heroMark{width:180px;height:180px;opacity:.8}.heroMark:after{inset:52px}.actions{display:flex;gap:8px;flex-wrap:wrap;margin-top:14px}.stats{display:grid;grid-template-columns:repeat(4,1fr);gap:10px}.stats article{padding:16px;border:1px solid var(--line);border-radius:19px;background:#0c2b3a}.stats small,.liveStats small{display:block;color:var(--muted)}.stats b{display:block;font-size:1.7rem;margin-top:5px}.panel{padding:18px}.section,.title{display:flex;justify-content:space-between;align-items:end;gap:12px}.section h2,.title h1{margin:5px 0}.list{display:grid;gap:8px}.list.empty,.empty{color:var(--muted);padding:20px;border:1px dashed var(--line);border-radius:16px}.item{padding:12px;border-radius:15px;background:#ffffff0a;display:grid;grid-template-columns:auto 1fr auto;gap:10px;align-items:center}.item span{font-size:1.3rem}.item small{color:var(--muted)}.rec{width:14px;height:14px;border-radius:50%;background:var(--red);box-shadow:0 0 0 8px #ff405720;animation:pulse 1.2s infinite}@keyframes pulse{50%{transform:scale(.6)}}.liveStats{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin:15px 0}.liveStats div{padding:11px;background:#0002;border-radius:13px}.mapBox{padding:10px;position:relative}.map{height:min(70vh,720px);min-height:480px;border-radius:20px}.mapBtns{position:absolute;z-index:500;right:22px;top:22px;display:grid;gap:8px}.mapBtn{width:62px;height:61px;border:0;border-radius:17px;font-size:1.3rem;font-weight:950}.mapBtn small{display:block;font-size:.65rem}.mapBtn.lime{background:var(--lime)}.mapBtn.orange{background:var(--orange);color:#fff}.mapBtn.blue{background:var(--blue);color:#fff}.recordGrid{display:grid;grid-template-columns:1fr 1fr;gap:12px}.recordCard{border:1px solid var(--line);border-radius:23px;min-height:160px;padding:20px;color:#fff;text-align:left;display:grid;grid-template-columns:auto 1fr;gap:13px;align-content:center}.recordCard span{grid-row:1/3;font-size:2rem}.recordCard b{font-size:1.25rem}.recordCard small{color:#ffffffaa}.recordCard.wildlife{background:linear-gradient(135deg,#0b5668,#153b31)}.recordCard.risk{background:linear-gradient(135deg,#7b321c,#4a1723)}.recordCard.marker{background:linear-gradient(135deg,#4b2a61,#17374e)}.recordCard.photo{background:linear-gradient(135deg,#164677,#40224d)}.perm{display:grid;grid-template-columns:auto 1fr auto;gap:10px;padding:10px 0;border-bottom:1px solid #ffffff10}.perm small{color:var(--muted)}.perm i{font-style:normal;color:#8499a3}.perm i.ok{color:var(--lime)}.search{margin:3px 0}.filters{display:flex;gap:7px;overflow:auto}.feed{display:grid;grid-template-columns:1fr 1fr;gap:12px}.post{border:1px solid var(--line);border-radius:22px;overflow:hidden;background:#0b2b3a}.postMedia{height:210px;display:grid;place-items:center;background:linear-gradient(135deg,#155469,#213f1d);font-size:4rem}.postMedia img{width:100%;height:100%;object-fit:cover}.postBody{padding:15px}.postBody h3{margin:0}.postBody p{color:#b5c9d2}.postMeta{color:var(--muted);font-size:.78rem}.postActions{display:flex;gap:6px}.postActions button{flex:1;border:1px solid var(--line);background:#ffffff0b;color:#fff;border-radius:11px;padding:8px}.profileHero{overflow:hidden}.cover{height:170px;background:linear-gradient(120deg,#0d5b6e,#204c27,#632b51)}.profileHead{display:flex;align-items:end;gap:15px;padding:0 20px 15px;margin-top:-44px}.profilePic{position:relative;width:96px;height:96px;border-radius:28px;border:5px solid var(--panel);background:linear-gradient(135deg,var(--blue),var(--pink));color:#fff;font-size:2rem;font-weight:950;overflow:hidden}.profilePic i{position:absolute;bottom:2px;right:2px;background:var(--lime);color:#071720;border-radius:50%;width:25px;height:25px;font-style:normal}.profileHead h1{margin:4px 0}.profileHead p{color:var(--muted)}.profileStats{display:grid;grid-template-columns:repeat(3,1fr);border-top:1px solid var(--line)}.profileStats div{text-align:center;padding:12px}.profileStats b{display:block;font-size:1.3rem}.profileStats small{color:var(--muted)}nav{position:fixed;z-index:20;bottom:0;left:50%;transform:translateX(-50%);width:min(1120px,100%);display:grid;grid-template-columns:repeat(5,1fr);padding:8px 9px calc(8px + var(--safe));background:#04131ef5;border-top:1px solid var(--line)}nav button{border:0;background:none;color:#8fa6b1;padding:6px;font-weight:800}nav button span{display:block;font-size:1.2rem}nav button.on{color:var(--lime)}nav .plus span{width:42px;height:42px;background:var(--lime);color:#071720;border-radius:50%;display:grid;place-items:center;margin:-18px auto 2px}.sos{position:fixed;z-index:21;right:max(14px,calc((100vw - 1120px)/2 + 14px));bottom:calc(85px + var(--safe));width:64px;height:64px;border-radius:50%;border:4px solid #ffffff25;background:var(--red);color:#fff;font-weight:1000}.modal{position:fixed;z-index:50;inset:0;background:#000c;display:grid;place-items:end center;padding:12px;backdrop-filter:blur(7px)}.sheet{width:min(700px,100%);max-height:94vh;overflow:auto;padding:20px;border-radius:28px 28px 16px 16px;background:linear-gradient(155deg,#113849,#071e2b);border:1px solid var(--line)}.close{float:right;width:38px;height:38px;border-radius:50%;border:0;background:#ffffff12;color:#fff}.sheet h2{margin:5px 0}.sheet p.intro{color:var(--muted)}.preview{height:230px;border-radius:16px;background:linear-gradient(135deg,#123b4d,#173625);display:grid;place-items:center;overflow:hidden}.preview img{width:100%;height:100%;object-fit:contain}.capture{display:flex;gap:7px;flex-wrap:wrap;margin:9px 0}.toggle{display:flex;gap:8px;padding:11px;border-radius:14px;background:#ffffff0a}.locBadge{padding:10px;border-radius:13px;background:#168cff18;color:#b5ddff}.ai{padding:11px;border:1px solid #bdff1830;border-radius:15px;background:#bdff1810}.ai button{width:100%;padding:9px;border:0;border-radius:10px;background:#ffffff12;color:#fff;margin-top:5px;text-align:left}.sosSheet{background:linear-gradient(155deg,#12303c,#23111b)}.sosState{text-align:center;padding:15px;border-radius:18px;background:#ffffff0b;margin:12px 0}.sosMain{width:100%;height:105px;border:0;border-radius:25px;background:var(--red);color:#fff;font-size:1.8rem;font-weight:1000}.sosGrid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:10px}.sosGrid button,.sosGrid a{padding:13px;border-radius:14px;border:1px solid var(--line);background:#ffffff0c;color:#fff;text-decoration:none}.flash{position:fixed;z-index:100;inset:0;background:#fff;animation:fl .5s infinite;display:grid;place-items:center;align-content:center;color:#071720;pointer-events:none}.flash b{font-size:20vw}.flash span{font-size:5vw;font-weight:1000}@keyframes fl{50%{background:var(--red)}}.toasts{position:fixed;z-index:200;left:50%;bottom:110px;transform:translateX(-50%);display:grid;gap:7px;width:min(420px,88vw);pointer-events:none}.toast{padding:11px;border-radius:13px;background:#113444;border:1px solid var(--line)}.leaflet-popup-content-wrapper,.leaflet-popup-tip{background:#092433;color:#fff}@media(max-width:780px){.auth{grid-template-columns:1fr}.authHero{display:none}.feed{grid-template-columns:1fr}.stats{grid-template-columns:1fr 1fr}.hero{grid-template-columns:1fr}.heroMark{position:absolute;right:-40px;opacity:.2}.recordGrid{grid-template-columns:1fr}}@media(max-width:600px){header{padding:10px 11px}.brand b{font-size:1rem}.status{display:none}main{padding:6px 10px calc(100px + var(--safe))}.hero{padding:23px;min-height:255px}.hero h1{font-size:2.4rem}.panel{padding:15px}.map{height:65vh;min-height:430px}.mapBtns{right:17px;top:17px}.title{align-items:flex-start}.two{grid-template-columns:1fr}.liveStats{grid-template-columns:1fr 1fr}.modal{padding:0}.sheet{border-radius:27px 27px 0 0;max-height:96vh}.sosGrid{grid-template-columns:1fr 1fr}.profileHead{padding:0 14px 14px}.profilePic{width:85px;height:85px}}