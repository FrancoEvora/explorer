st{error}=await X.sb.from('trails').insert(row);if(error)return X.toast(error.message,'error');if(S.points.length)await X.sb.from('trail_points').insert(S.points.map((p,i)=>({user_id:X.user.id,trail_id:S.trail.id,sequence_no:i,recorded_at:p.time,latitude:p.lat,longitude:p.lng,altitude:p.alt,accuracy:p.accuracy})));S.trail=null;S.points=[];localStorage.removeItem('explorer-active');$('liveTrail').classList.add('hide');$('trailText').textContent='Trilha salva com sucesso.';$('statDist').textContent='0 km';X.toast('Trilha finalizada.','success');X.loadMine();X.loadFeed();X.renderMap()}function clearWatch(){if(S.watch)navigator.geolocation.clearWatch(S.watch);if(S.timer)clearInterval(S.timer);S.watch=S.timer=null}function restoreTrail(){try{const s=JSON.parse(localStorage.getItem('explorer-active'));if(!s?.trail)return;S.trail=s.trail;S.points=s.points||[];S.pausedMs=s.pausedMs||0;$('liveTrail').classList.remove('hide');$('liveName').textContent=S.trail.name;S.watch=navigator.geolocation.watchPosition(track,()=>{},{enableHighAccuracy:true});S.timer=setInterval(renderLive,1000);renderLive();X.renderMap()}catch{}}function captureBlock(prefix,icon){return`<div class="preview" id="${prefix}Preview"><span style="font-size:3rem">${icon}</span></div><div class="capture"><label class="btn blue">Câmera<input id="${prefix}Cam" class="hide" type="file" accept="image/*" capture="environment"></label><label class="btn ghost">Galeria<input id="${prefix}Gallery" class="hide" type="file" accept="image/*"></label></div>`}function bindPhoto(prefix,key){for(const id of[`${prefix}Cam`,`${prefix}Gallery`])$(id).onchange=e=>{S[key]=e.target.files[0];if(S[key])$(''+prefix+'Preview').innerHTML=`<img src="${URL.createObjectURL(S[key])}">`}}function openObservation(){sheet('Nova observação','Registre fauna, flora, rastros e sons com geolocalização.',`<form id="obsForm" class="stack">${captureBlock('obs','◉')}<button id="identify" class="btn lime" type="button">✦ Identificação inteligente</button><div id="aiBox" class="ai hide"></div><div class="two"><label class="field">Grupo<select id="oType"><option>Ave</option><option>Mamífero</option><option>Réptil</option><option>Anfíbio</option><option>Inseto</option><option>Planta</option><option>Fungo</option><option>Outro</option></select></label><label class="field">Nome comum<input id="oName" required></label></div><label class="field">Nome científico<input id="oSci"></label><label class="field">Notas<textarea id="oNotes"></textarea></label><button id="audioBtn" type="button" class="btn ghost">● Gravar áudio</button><label class="toggle"><input id="oPublic" type="checkbox" checked> Pública</label><label class="field">Privacidade do local<select id="oGeo"><option value="exact">Exata</option><option value="obscured">Aproximada</option><option value="private">Privada</option></select></label><div class="actions"><button class="btn ghost" type="button" data-close>Cancelar</button><button class="btn lime">Salvar</button></div></form>`);S.photo=null;S.audio=null;bindPhoto('obs','photo');$('identify').onclick=identify;$('audioBtn').onclick=recordAudio;$('obsForm').onsubmit=saveObs}async function identify(){if(!S.photo)return X.toast('Adicione uma foto.','error');$('aiBox').classList.remove('hide');$('aiBox').innerHTML='Analisando imagem e espécies próximas…';let suggestions=[];try{if(!window.mobilenet){await loadScript('https://cdn.jsdelivr.net/npm/@tensorflow/tfjs@4.20.0/dist/tf.min.js');await loadScript('https://cdn.jsdelivr.net/npm/@tensorflow-models/mobilenet@2.1.1/dist/mobilenet.min.js')}const img=new Image();img.src=URL.createObjectURL(S.photo);await img.decode();const model=await window.mobilenet.load();suggestions=(await model.classify(img,3)).map(x=>({name:x.className,confidence:x.probability}))}catch{}try{const c=await X.locate();const r=await fetch(`https://api.inaturalist.org/v1/observations/species_counts?lat=${c.lat}&lng=${c.lng}&radius=50&per_page=5`),j=await r.json();(j.results||[]).forEach(x=>suggestions.push({name:x.taxon.preferred_common_name||x.taxon.name,sci:x.taxon.name,confidence:null}))}catch{}$('aiBox').innerHTML=suggestions.length?'<b>Sugestões — confirme antes de salvar</b>'+suggestions.slice(0,6).map(x=>`<button type="button" class="aiOpt" data-name="${X.esc(x.name)}" data-sci="${X.esc(x.sci||'')}">${X.esc(x.name)} <small>${x.confidence?Math.round(x.confidence*100)+'%':X.esc(x.sci||'próxima de você')}</small></button>`).join(''):'Não consegui sugerir uma espécie. Você ainda pode preencher manualmente.';$$('.aiOpt').forEach(b=>b.onclick=()=>{$('oName').value=b.dataset.name;$('oSci').value=b.dataset.sci})}function loadScript(src){return new Promise((res,rej)=>{const s=document.createElement('script');s.src=src;s.onload=res;s.onerror=rej;document.head.append(s)})}async function recordAudio(){if(S.mediaRecorder?.state==='recording'){S.mediaRecorder.stop();$('audioBtn').textContent='Áudio gravado';return}try{const stream=await navigator.mediaDevices.getUserMedia({audio:true}),chunks=[];S.mediaRecorder=new MediaRecorder(stream);S.mediaRecorder.ondataavailable=e=>chunks.push(e.data);S.mediaRecorder.onstop=()=>{S.audio=new File([new Blob(chunks,{type:S.mediaRecorder.mimeType})],'audio-campo.webm',{type:S.mediaRecorder.mimeType});stream.getTracks().forEach(t=>t.stop())};S.mediaRecorder.start();$('audioBtn').textContent='■ Parar áudio'}catch(e){X.toast(e.message,'error')}}async function saveObs(e){e.preventDefault();if(!X.user)return X.toast('Entre para salvar.','error');const c=await X.locate(),id=X.uid('obs'),geo=$('oGeo').value,pub=$('oPublic').checked;let lat=c.lat,lng=c.lng;if(geo==='obscured'){lat=Math.round(lat*100)/100;lng=Math.round(lng*100)/100}if(geo==='private'&&!pub){lat=c.lat;lng=c.lng}const row={id,user_id:X.user.id,trail_id:S.trail?.id||null,type:$('oType').value,status:'Registrado',species:$('oName').value,common_name:$('oName').value,scientific_name:$('oSci').value,notes:$('oNotes').value,latitude:lat,longitude:lng,altitude:c.alt,is_public:pub,geoprivacy:geo};const{error}=await X.sb.from('observations').insert(row);if(error)return X.toast(error.message,'error');if(S.photo){const path=await X.upload(S.photo,'observations');await X.sb.from('media').insert({id:X.uid('media'),user_id:X.user.id,observation_id:id,kind:'photo',name:S.photo.name,mime_type:S.photo.type,size_bytes:S.photo.size,storage_path:path,is_public:pub})}if(S.audio){const path=await X.upload(S.audio,'observations');await X.sb.from('media').insert({id:X.uid('media'),user_id:X.user.id,observation_id:id,kind:'audio',name:S.audio.name,mime_type:S.audio.type,size_bytes:S.audio.size,storage_path:path,is_public:pub})}X.closeModal();X.toast('Observação salva.','success');X.loadMine();X.loadFeed();X.renderMap()}function openRisk(){sheet('Registrar risco','Crie um alerta geolocalizado com gravidade, descrição e foto.',`<form id="riskForm" class="stack">${captureBlock('risk','⚠')}<div class="two"><label class="field">Tipo<select id="rType"><option value="buraco">Buraco</option><option value="erosao">Erosão</option><option value="arvore">Árvore caída</option><option value="ponte">Ponte danificada</option><option value="alagamento">Alagamento</option><option value="lama">Lamaçal</option><option value="queda">Risco de queda</option><option value="animal">Animal agressivo</option><option value="incendio">Incêndio</option><option value="sem_sinal">Sem sinal</option><option value="outro">Outro</option></select></label><label class="field">Gravidade<select id="rSeverity"><option value="low">Baixa</option><option value="medium">Média</option><option value="high">Alta</option><option value="critical">Crítica</option></select></label></div><label class="field">Título<input id="rTitle" required></label><label class="field">Descrição<textarea id="rNotes"></textarea></label><label class="toggle"><input id="rPublic" type="checkbox" checked> Compartilhar alerta</label><div class="actions"><button class="btn ghost" type="button" data-close>Cancelar</button><button class="btn danger">Publicar</button></div></form>`);S.riskPhoto=null;bindPhoto('risk','riskPhoto');$('riskForm').onsubmit=saveRisk}async function saveRisk(e){e.preventDefault();if(!X.user)return X.toast('Entre para salvar.','error');const c=await X.locate(),id=X.uid('risk'),pub=$('rPublic').checked;const{error}=await X.sb.from('risks').insert({id,user_id:X.user.id,trail_id:S.trail?.id||null,type:$('rType').value,severity:$('rSeverity').value,title:$('rTitle').value,notes:$('rNotes').value,latitude:c.lat,longitude:c.lng,altitude:c.alt,is_public:pub,status:'active'});if(error)return X.toast(error.message,'error');if(S.riskPhoto){const path=await X.upload(S.riskPhoto,'risks');await X.sb.from('media').insert({id:X.uid('media'),user_id:X.user.id,risk_id:id,kind:'riskPhoto',name:S.riskPhoto.name,mime_type:S.riskPhoto.type,size_bytes:S.riskPhoto.size,storage_path:path,is_public:pub})}X.closeModal();X.toast('Alerta publicado.','success');X.loadMine();X.loadFeed();X.renderMap()}function openMarker(){sheet('Marcar posição','Adicione água, mirante, acesso, abrigo ou outro ponto útil.',`<form id="markerForm" class="stack"><div class="two"><label class="field">Categoria<select id="mKind"><option value="agua">Água</option><option value="vista">Mirante</option><option value="descanso">Descanso</option><option value="abrigo">Abrigo</option><option value="acesso">Acesso</option><option value="camping">Camping</option><option value="outro">Outro</option></select></label><label class="field">Título<input id="mTitle" required></label></div><label class="field">Descrição<textarea id="mDesc"></textarea></label><label class="toggle"><input id="mPublic" type="checkbox" checked> Ponto público</label><div class="actions"><button class="btn ghost" type="button" data-close>Cancelar</button><button class="btn lime">Salvar ponto</button></div></form>`);$('markerForm').onsubmit=saveMarker}async function saveMarker(e){e.preventDefault();if(!X.user)return X.toast('Entre para salvar.','error');const c=await X.locate();const{error}=await X.sb.from('map_markers').insert({id:X.uid('mark'),user_id:X.user.id,trail_id:S.trail?.id||null,kind:$('mKind').value,title:$('mTitle').value,description:$('mDesc').value,latitude:c.lat,longitude:c.lng,altitude:c.alt,accuracy:c.accuracy,is_public:$('mPublic').checked});if(error)return X.toast(error.message,'error');X.closeModal();X.toast('Posição marcada.','success');X.renderMap()}async function saveProfile(e){e.preventDefault();const{error}=await X.sb.from('profiles').update({full_name:$('pName').value,username:$('pUser').value.toLowerCase().replace(/[^a-z0-9_-]/g,''),bio:$('pBio').value,location_text:$('pLocation').value,camera_gear:$('pGear').value}).eq('id',X.user.id);if(error)return X.toast(error.message,'error');X.toast('Perfil atualizado.','success');X.loadProfile()}async function uploadAvatar(e){const f=e.target.files[0];if(!f)return;try{const path=await X.upload(f,'profile');await X.sb.from('profiles').update({avatar_path:path}).eq('id',X.user.id);X.loadProfile();X.toast('Foto atualizada.','success')}catch(e){X.toast(e.message,'error')}}function openContact(){sheet('Contato de emergência','O contato é privado e usado apenas por você.',`<form id="contactForm" class="stack"><label class="field">Nome<input id="cName" required></label><label class="field">Telefone<input id="cPhone" required inputmode="tel"></label><label class="field">Relação<input id="cRel"></label><label class="toggle"><input id="cPrimary" type="checkbox"> Contato principal</label><button class="btn lime">Salvar</button></form>`);$('contactForm').onsubmit=saveContact}async function saveContact(e){e.preventDefault();const{error}=await X.sb.from('emergency_contacts').insert({user_id:X.user.id,name:$('cName').value,phone:$('cPhone').value,relationship:$('cRel').value,is_primary:$('cPrimary').checked});if(error)return X.toast(error.message,'error');X.closeModal();loadContacts()}async function loadContacts(){if(!X.user)return;const{data}=await X.sb.from('emergency_contacts').select('*').eq('user_id',X.user.id).order('is_primary',{ascending:false});$('contacts').classList.toggle('empty',!data?.length);$('contacts').innerHTML=data?.length?data.map(c=>`<div class="item"><span>☎</span><div><b>${X.esc(c.name)}</b><small>${X.esc(c.phone)}${c.relationship?' · '+X.esc(c.relationship):''}</small></div><a class="btn ghost" href="tel:${X.esc(c.phone)}">Ligar</a></div>`).join(''):'Nenhum contato cadastrado.'}function openSos(){sheet('Modo SOS','Sinalização sonora, voz, luz e compartilhamento de localização. Não substitui serviços oficiais de emergência.',`<div class="sosState" id="sosState"><b id="sosText">SOS desligado</b><p id="sosLoc">Localização aguardando</p></div><button id="sosToggle" class="sosMain">ATIVAR SOS</button><div class="sosGrid"><button id="sosShare">↗ Compartilhar localização</button><button id="sosWhats">WhatsApp</button><a href="tel:190">Ligar 190</a><button id="sosDiscrete">Modo discreto</button></div>`,`sosSheet`);$('sosToggle').onclick=toggleSos;$('sosShare').onclick=()=>shareSos(false);$('sosWhats').onclick=()=>shareSos(true);$('sosDiscrete').onclick=()=>toggleSos(true)}async function toggleSos(discrete=false){if(S.sos)return stopSos();S.sos=true;S.discrete=discrete;$('sosText').textContent=discrete?'SOS discreto ativo':'SOS ativo';$('sosToggle').textContent='DESLIGAR SOS';if(!discrete){startSound();speak();S.voiceTimer=setInterval(speak,6500);$('flash').classList.remove('hide');S.flashTimer=setInterval(()=>$('flash').classList.toggle('hide'),400);tryTorch(true)}await shareLocationText()}function startSound(){try{S.audioCtx=new(AudioContext||webkitAudioContext)();for(const f of[740,980]){const o=S.audioCtx.createOscillator(),g=S.audioCtx.createGain();o.type='sawtooth';o.frequency.value=f;g.gain.value=.32;o.connect(g).connect(S.audioCtx.destination);o.start();S.osc.push(o)}}catch{}}function speak(){if(!speechSynthesis)return;const u=new SpeechSynthesisUtterance('SOS. Preciso de ajuda. Minha localização está disponível. Envie ajuda imediatamente.');u.lang='pt-BR';u.rate=.9;u.volume=1;speechSynthesis.cancel();speechSynthesis.speak(u)}async function stopSos(){S.sos=false;clearInterval(S.voiceTimer);clearInterval(S.flashTimer);speechSynthesis?.cancel();S.osc.forEach(o=>{try{o.stop()}catch{}});S.osc=[];try{S.audioCtx?.close()}catch{}$('flash').classList.add('hide');tryTorch(false);if($('sosText'))$('sosText').textContent='SOS desligado';if($('sosToggle'))$('sosToggle').textContent='ATIVAR SOS'}async function tryTorch(on){try{if(on){S.torchStream=await navigator.mediaDevices.getUserMedia({video:{facingMode:'environment'}});const t=S.torchStream.getVideoTracks()[0];if(t.getCapabilities?.().torch)await t.applyConstraints({advanced:[{torch:true}]})}else if(S.torchStream){S.torchStream.getTracks().forEach(t=>t.stop());S.torchStream=null}}catch{}}async function shareLocationText(){try{const c=await X.locate();if($('sosLoc'))$('sosLoc').textContent=`${c.lat.toFixed(6)}, ${c.lng.toFixed(6)}`;return`SOS! Preciso de ajuda. Localização: https://maps.google.com/?q=${c.lat},${c.lng}`}catch{return'SOS! Preciso de ajuda. Não foi possível obter a localização.'}}async function shareSos(whats){const text=await shareLocationText();if(whats)window.open('https://wa.me/?text='+encodeURIComponent(text),'_blank');else if(navigator.share)await navigator.share({title:'SOS Explorer',text});else{await navigator.clipboard.writeText(text);X.toast('Mensagem copiada.','success')}}function openPasswordReset(){sheet('Nova senha','Defina uma nova senha para sua conta.',`<form id="newPassForm" class="stack"><label class="field">Nova senha<input id="newPass" type="password" minlength="8" required></label><label class="field">Confirmar<input id="newPass2" type="password" minlength="8" required></label><button class="btn lime">Salvar nova senha</button></form>`);$('newPassForm').onsubmit=async e=>{e.preventDefault();if($('newPass').value!==$('newPass2').value)return X.toast('As senhas não coincidem.','error');const{error}=await X.sb.auth.updateUser({password:$('newPass').value});if(error)return X.toast(error.message,'error');X.closeModal();X.toast('Senha atualizada.','success')}}async function showTrail(id){X.show('mapPage');const{data}=await X.sb.from('trail_points').select('*').eq('trail_id',id).order('sequence_no');if(data?.length){S.points=data.map(p=>({lat:p.latitude,lng:p.longitude}));X.renderMap();X.map.fitBounds(S.points.map(p=>[p.lat,p.lng]),{padding:[25,25]})}}
})();
