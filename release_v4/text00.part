<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
  <meta name="theme-color" content="#061722">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-title" content="Explorer">
  <meta name="description" content="Rede social de aventura, trilhas, fotografia e vida selvagem.">
  <title>Explorer 4.0</title>
  
  <link rel="icon" href="assets/explorer-mark.svg" type="image/svg+xml">
  <link rel="apple-touch-icon" href="assets/icon-192.png">
  <link rel="preconnect" href="https://unpkg.com">
  <link rel="preconnect" href="https://cdn.jsdelivr.net">
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="">
  <style>:root{
  --bg:#04131e;--bg2:#071c29;--panel:#0c2a3a;--panel2:#103647;--panel3:#0a2330;
  --text:#f5fbff;--muted:#9bb4c0;--line:rgba(255,255,255,.12);
  --lime:#bcff18;--lime2:#78e400;--blue:#168cff;--orange:#ff721c;--pink:#ff3d8d;--danger:#ff4057;
  --shadow:0 22px 70px rgba(0,0,0,.38);--radius:24px;--safe-bottom:env(safe-area-inset-bottom,0px)
}
*{box-sizing:border-box}html{background:var(--bg)}body{margin:0;min-height:100vh;background:radial-gradient(circle at 10% -5%,#13566a 0,transparent 36rem),linear-gradient(180deg,#061924,#020b12 72%);color:var(--text);font-family:Inter,ui-sans-serif,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;-webkit-font-smoothing:antialiased}button,input,select,textarea{font:inherit}button{cursor:pointer}a{color:inherit}.hidden{display:none!important}.eyebrow{margin:0;color:var(--lime);font-size:.72rem;font-weight:950;letter-spacing:.16em;text-transform:uppercase}.muted{color:var(--muted)}
.boot-screen{position:fixed;inset:0;z-index:999;display:grid;place-items:center;background:radial-gradient(circle at 50% 0,#164f60,#04131e 55%,#020910);transition:opacity .35s}.boot-card{text-align:center;width:min(390px,88vw)}.boot-logo{width:104px;height:104px;filter:drop-shadow(0 20px 34px rgba(0,0,0,.45))}.boot-card h1{font-size:2.5rem;margin:12px 0 4px;letter-spacing:-.06em}.boot-card p{color:var(--muted)}.loading-bar{height:7px;border-radius:999px;overflow:hidden;background:rgba(255,255,255,.1);margin-top:24px}.loading-bar i{display:block;width:35%;height:100%;background:linear-gradient(90deg,var(--lime),var(--blue),var(--pink));animation:loading 1.25s ease-in-out infinite}@keyframes loading{from{transform:translateX(-110%)}to{transform:translateX(390%)}}
.auth-screen{min-height:100vh;display:grid;place-items:center;padding:28px}.auth-shell{width:min(1060px,100%);display:grid;grid-template-columns:1.1fr .8fr;gap:26px;align-items:stretch}.auth-visual,.auth-card{border:1px solid var(--line);border-radius:32px;box-shadow:var(--shadow);backdrop-filter:blur(22px)}.auth-visual{padding:clamp(30px,6vw,66px);display:flex;flex-direction:column;justify-content:center;min-height:610px;background:linear-gradient(145deg,rgba(12,55,66,.93),rgba(7,28,41,.95)),radial-gradient(circle at 80% 20%,rgba(188,255,24,.24),transparent 40%);overflow:hidden;position:relative}.auth-visual:after{content:"";position:absolute;width:380px;height:380px;border-radius:50%;right:-170px;bottom:-160px;background:conic-gradient(from 40deg,var(--lime),var(--blue),var(--pink),var(--orange),var(--lime));filter:blur(70px);opacity:.18}.auth-logo{width:92px;height:92px}.auth-visual h1{font-size:clamp(2.5rem,5vw,4.5rem);line-height:.98;letter-spacing:-.075em;margin:18px 0;max-width:11ch}.auth-visual>p:not(.eyebrow){max-width:52ch;color:#bdd0d8;line-height:1.65}.auth-feature-row{display:flex;gap:9px;flex-wrap:wrap;margin-top:25px}.auth-feature-row span{padding:9px 13px;border-radius:999px;border:1px solid rgba(255,255,255,.13);background:rgba(255,255,255,.06);font-size:.82rem;font-weight:800}.auth-card{padding:28px;background:linear-gradient(160deg,rgba(16,52,69,.96),rgba(5,23,34,.97));align-self:center}.brand-inline{display:flex;align-items:center;gap:12px;margin-bottom:22px}.brand-inline img{width:54px;height:54px}.brand-inline strong{display:block;font-size:1.55rem;letter-spacing:-.04em}.brand-inline small{color:var(--muted)}
.segmented{display:grid;grid-template-columns:repeat(3,1fr);gap:5px;background:rgba(0,0,0,.17);padding:5px;border-radius:16px;margin-bottom:20px}.segmented button{border:0;padding:11px 8px;border-radius:12px;background:transparent;color:#9eb7c2;font-weight:850}.segmented button.active{background:var(--lime);color:#06141d;box-shadow:0 8px 22px rgba(188,255,24,.18)}
.form-stack{display:grid;gap:14px}.field{display:grid;gap:7px;color:#d8e7ed;font-size:.84rem;font-weight:800}.field input,.field select,.field textarea,.search-bar input{width:100%;border:1px solid rgba(255,255,255,.14);background:#061923;color:#fff;border-radius:15px;padding:13px 14px;outline:0;transition:border .2s,box-shadow .2s}.field textarea{resize:vertical}.field input:focus,.field select:focus,.field textarea:focus,.search-bar input:focus{border-color:var(--lime);box-shadow:0 0 0 3px rgba(188,255,24,.15)}.input-action{display:grid;grid-template-columns:1fr auto;border:1px solid rgba(255,255,255,.14);border-radius:15px;background:#061923;overflow:hidden}.input-action input{border:0;border-radius:0;background:transparent}.input-action button{border:0;background:transparent;color:var(--lime);padding:0 14px;font-weight:850}.two-cols{display:grid;grid-template-columns:1fr 1fr;gap:12px}.btn{border:0;min-height:47px;padding:11px 17px;border-radius:15px;font-weight:950;display:inline-flex;align-items:center;justify-content:center;gap:7px;text-decoration:none;transition:transform .15s,filter .15s}.btn:active{transform:scale(.975)}.btn:disabled{opacity:.48;cursor:not-allowed}.btn.primary,.btn.lime{background:linear-gradient(135deg,var(--lime),var(--lime2));color:#071720}.btn.blue{background:linear-gradient(135deg,var(--blue),#075edb);color:#fff}.btn.orange{background:linear-gradient(135deg,var(--orange),#ef4718);color:#fff}.btn.danger{background:linear-gradient(135deg,var(--danger),#b9002e);color:#fff}.btn.ghost{background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.12);color:#fff}.btn.small{min-height:38px;padding:8px 12px;font-size:.8rem}.btn.wide{width:100%}.text-btn{border:0;background:none;color:var(--lime);font-weight:850;padding:7px}.notice{padding:12px 14px;border-radius:15px;margin-top:12px;background:rgba(255,255,255,.07);line-height:1.45;font-size:.85rem}.notice.error{background:rgba(255,64,87,.15);color:#ffc3cb;border:1px solid rgba(255,64,87,.3)}.notice.success{background:rgba(188,255,24,.11);color:#dcff8a;border:1px solid rgba(188,255,24,.25)}.notice.muted{color:var(--muted)}
.app-shell{min-height:100vh}.topbar{max-width:1120px;margin:auto;padding:14px 18px;display:flex;align-items:center;justify-content:space-between;gap:18px}.brand-button{display:flex;align-items:center;gap:11px;border:0;background:none;color:#fff;text-align:left;padding:0}.brand-button img{width:58px;height:58px}.brand-button span{display:grid}.brand-button small{color:var(--lime);font-weight:950;letter-spacing:.12em}.brand-button strong{font-size:1.35rem;letter-spacing:-.035em}.top-actions{display:flex;align-items:center;gap:10px}.status-pill{display:flex;align-items:center;gap:7px;padding:8px 11px;border-radius:999px;background:rgba(255,255,255,.07);font-size:.75rem;color:#c4d6de}.status-pill i{width:8px;height:8px;border-radius:50%;background:#f5c542}.status-pill.online i{background:var(--lime);box-shadow:0 0 0 4px rgba(188,255,24,.12)}.status-pill.offline i{background:var(--danger)}.avatar-button{width:43px;height:43px;border-radius:50%;border:2px solid rgba(188,255,24,.55);background:linear-gradient(135deg,var(--blue),var(--pink));color:#fff;font-weight:950;overflow:hidden}.avatar-button img{width:100%;height:100%;object-fit:cover}.content{max-width:1120px;margin:auto;padding:10px 18px calc(105px + var(--safe-bottom))}.screen{display:none;gap:16px}.screen.active{display:grid}.hero-card